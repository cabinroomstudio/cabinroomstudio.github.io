<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cabin Room Studio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,700;1,300&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ocean-deep:  #0D3B5E;
    --ocean-mid:   #0077B6;
    --ocean-light: #00B4D8;
    --sand:        #E9C46A;
    --foam:        #E8F4FD;
    --ink:         #0D1B2A;
    --mist:        #8EAFC2;
    --white:       #FFFFFF;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    color: var(--ink);
    background: var(--white);
    line-height: 1.6;
  }

  /* ── NAV ── */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 18px 48px;
    background: rgba(13,27,42,0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .nav-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.2rem;
    color: var(--white);
    letter-spacing: 0.02em;
    text-decoration: none;
  }
  .nav-links { display: flex; gap: 36px; list-style: none; }
  .nav-links a {
    color: var(--mist);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color 0.2s;
  }
  .nav-links a:hover { color: var(--white); }

  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    background: linear-gradient(155deg, var(--ocean-deep) 0%, var(--ocean-mid) 55%, var(--ocean-light) 100%);
    display: flex; flex-direction: column;
    justify-content: center; align-items: center;
    text-align: center;
    padding: 120px 24px 80px;
    position: relative; overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .hero-eyebrow {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sand);
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    color: var(--white);
    line-height: 1.08;
    max-width: 800px;
    margin-bottom: 24px;
  }
  .hero h1 em {
    font-style: italic;
    color: var(--sand);
  }
  .hero-sub {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: rgba(255,255,255,0.72);
    max-width: 520px;
    margin-bottom: 48px;
    font-weight: 300;
  }
  .hero-cta {
    display: inline-block;
    padding: 14px 36px;
    background: var(--sand);
    color: var(--ink);
    border-radius: 40px;
    font-weight: 700;
    font-size: 0.95rem;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 4px 24px rgba(233,196,106,0.35);
  }
  .hero-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 32px rgba(233,196,106,0.45); }

  .wave {
    position: absolute; bottom: -2px; left: 0; width: 100%;
    line-height: 0;
  }

  /* ── ABOUT ── */
  .about {
    background: var(--white);
    padding: 96px 24px;
    display: flex; justify-content: center;
  }
  .about-inner {
    max-width: 680px;
    text-align: center;
  }
  .section-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ocean-mid);
    margin-bottom: 14px;
  }
  .about h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.2;
    margin-bottom: 24px;
    color: var(--ink);
  }
  .about p {
    color: #3D5A6E;
    font-size: 1.05rem;
    line-height: 1.8;
    font-weight: 300;
  }

  /* ── APPS ── */
  .apps {
    background: var(--foam);
    padding: 96px 24px;
  }
  .apps-inner { max-width: 960px; margin: 0 auto; }
  .apps h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    text-align: center;
    margin-bottom: 56px;
    color: var(--ink);
  }
  .app-card {
    background: var(--white);
    border-radius: 24px;
    padding: 48px;
    display: flex;
    align-items: flex-start;
    gap: 36px;
    box-shadow: 0 4px 32px rgba(0,0,0,0.06);
    max-width: 720px;
    margin: 0 auto;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .app-card:hover { transform: translateY(-4px); box-shadow: 0 12px 48px rgba(0,0,0,0.1); }
  .app-icon {
    width: 96px; height: 96px;
    border-radius: 22px;
    flex-shrink: 0;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,119,182,0.2);
  }
  .app-icon img { width: 100%; height: 100%; object-fit: cover; }
  .app-info h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.7rem;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .app-info p {
    color: #3D5A6E;
    font-size: 0.98rem;
    line-height: 1.75;
    margin-bottom: 24px;
    font-weight: 300;
  }
  .app-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 10px 22px;
    background: var(--ink);
    color: var(--white);
    border-radius: 30px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .app-badge:hover { background: var(--ocean-mid); }
  .app-badge svg { width: 18px; height: 18px; fill: var(--white); }

  /* ── PIPELINE ── */
  .pipeline {
    background: var(--white);
    padding: 96px 24px;
  }
  .pipeline-inner { max-width: 960px; margin: 0 auto; }
  .pipeline h2 {
    font-family: 'DM Serif Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    text-align: center;
    margin-bottom: 16px;
    color: var(--ink);
  }
  .pipeline-sub {
    text-align: center;
    color: var(--mist);
    font-size: 0.98rem;
    margin-bottom: 56px;
    font-weight: 300;
  }
  .pipeline-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 28px;
  }
  .pipeline-card {
    border: 1.5px solid #D8EAF5;
    border-radius: 20px;
    padding: 36px 32px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .pipeline-card:hover { border-color: var(--ocean-light); box-shadow: 0 4px 24px rgba(0,180,216,0.12); }
  .pipeline-card::before {
    content: '';
    position: absolute; top: 0; left: 0;
    width: 4px; height: 100%;
    background: linear-gradient(180deg, var(--ocean-light), var(--ocean-mid));
  }
  .coming-tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ocean-mid);
    background: #E0F0FA;
    border-radius: 20px;
    padding: 4px 12px;
    margin-bottom: 16px;
  }
  .pipeline-card h3 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.35rem;
    margin-bottom: 10px;
    color: var(--ink);
  }
  .pipeline-card p {
    color: #3D5A6E;
    font-size: 0.93rem;
    line-height: 1.72;
    font-weight: 300;
  }

  /* ── FOOTER ── */
  footer {
    background: var(--ink);
    padding: 56px 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }
  .footer-logo {
    font-family: 'DM Serif Display', serif;
    font-size: 1.4rem;
    color: var(--white);
  }
  .footer-links { display: flex; gap: 32px; list-style: none; flex-wrap: wrap; justify-content: center; }
  .footer-links a {
    color: var(--mist);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: var(--white); }
  .footer-copy { color: #4A6375; font-size: 0.8rem; }

  @media (max-width: 640px) {
    nav { padding: 16px 20px; }
    .nav-links { gap: 18px; }
    .app-card { flex-direction: column; padding: 32px 24px; }
    footer { padding: 40px 24px; }
  }
</style>
</head>
